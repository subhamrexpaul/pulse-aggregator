      ],
      "id": "c7845c69-47fe-4755-88d6-5289bce8b4b4",
      "name": "Merge"
    },
    {
      "parameters": {
        "jsCode": "const seen = new Set();\nconst unique = [];\n\nfor (const item of $input.all()) {\n  const url = item.json.link || '';\n  if (!seen.has(url) && url !== '') {\n    seen.add(url);\n    unique.push({\n      json: {\n        source: item.json.source,\n        title: item.json.title,\n        link: url,\n        date: item.json.date,\n        summary: item.json.summary\n      }\n    });\n  }\n}\n\nreturn unique;"
      },
