    {
      "parameters": {
        "jsCode": "const items = $input.first().json.hits;\n\nreturn items.map(post => ({\n  json: {\n    source: 'Hacker News',\n    title: post.title,\n    link: post.url || `https://news.ycombinator.com/item?id=${post.objectID}`,\n    date: post.created_at,\n    summary: post.story_text?.slice(0, 150) || 'No description'\n  }\n}));"
      },
